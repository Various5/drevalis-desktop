# Glitchtip self-host environment. Copy to ``.env`` next to
# ``docker-compose.yml`` and fill in:
#
#   GLITCHTIP_SECRET_KEY        generate with:
#                                 openssl rand -base64 48
#   GLITCHTIP_DB_PASSWORD       generate with:
#                                 openssl rand -base64 24
#   GLITCHTIP_EMAIL_URL         optional. Defaults to consolemail://
#                                 which just prints emails to the
#                                 worker log — fine for alpha since
#                                 the only emails are password resets
#                                 for the single superuser.
#
# Keep ``.env`` out of git. ``.env.example`` (this file) is the
# committed template.

GLITCHTIP_SECRET_KEY=REPLACE_WITH_openssl_rand_-base64_48
GLITCHTIP_DB_PASSWORD=REPLACE_WITH_openssl_rand_-base64_24

# Optional: real SMTP for password-reset emails. Leave commented to
# stay on consolemail:// (logs to worker stdout).
# GLITCHTIP_EMAIL_URL=smtp://user:pass@smtp.example.com:587
