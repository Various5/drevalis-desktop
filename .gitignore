# ─── Owner-only key material — NEVER commit to this repo ──────────────
# Mint scripts and key material live OFF the repo (offline machine /
# password manager / VPS only). The license-server source IS in-tree
# under ``license-server/`` for maintenance, but its private keys and
# ``.env`` stay out per the secret patterns below.
scripts/mint_license.py
license_keys/

# ─── Secrets ───────────────────────────────────────────────────────────
*.pem
*.key
*.crt
!**/public_dummy*.pem

# ─── Screenshots / scratch ─────────────────────────────────────────────
screenshots/
.claude-plan.md
.claude/
*.zip
test.db
drevalis-dev.db
drevalis-dev.db-journal
drevalis-dev.db-shm
drevalis-dev.db-wal

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
# Anchor these to the repo root so scripts/build/ (per-OS build wrappers)
# isn't accidentally hidden.
/dist/
/build/
.venv/
venv/
.eggs/

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Storage (generated assets — too large for git) ───────────────────────────
storage/

# ── Sidecar binaries (downloaded by scripts/fetch_sidecars.py) ───────────────
# Keep the resources/bin/<platform>/ tree itself (via .gitkeep), but
# never commit the multi-MB binaries — they're provisioned at install /
# CI time. See ``scripts/fetch_sidecars.py``.
resources/bin/**/*.exe
resources/bin/**/*.dll
resources/bin/**/ffmpeg
resources/bin/**/ffprobe
resources/bin/**/redis-server
resources/bin/**/redis-cli

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ── Testing / CI ─────────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node (frontend, if any) ─────────────────────────────────────────────────
node_modules/

# ── Tauri build artifacts ────────────────────────────────────────────────────
tauri/src-tauri/target/
tauri/src-tauri/gen/

# ── Frontend build output ────────────────────────────────────────────────────
# Vite produces this on `npm run build`; it's bundled into the PyInstaller
# bundle / Tauri bundle at build time. Not source.
frontend/dist/

# ── Tauri updater signing keys ───────────────────────────────────────────────
# Private keys MUST NEVER be committed. The .pub file IS committed (it's
# what tauri.conf.json references for verifying signed update manifests).
.tauri-keys/*.key

# ── Scratch / diagnostic files ───────────────────────────────────────────────
# Stack traces / log captures the user opens for debugging. Not source.
checkthis.txt
*.diag.txt
*.diag.log
# package-lock.json IS committed — we want reproducible Docker builds via
# ``npm ci``. Keep this comment to remind future maintainers not to add it
# back to .gitignore.
*.tsbuildinfo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Docker ────────────────────────────────────────────────────────────────────
*.log
# Local-dev-only docker-compose override. Production deployments do not
# load this file (compose only auto-loads override.yml when present in
# the working directory of the operator running the command).
docker-compose.override.yml

# ── Scratch artefacts from verification / recovery passes ─────────────────────
.tmp_*

# Avoid stray '-' files from typo'd shell redirects
/-

# hatch-vcs auto-generates this at build time from the latest git tag.
# Checked-in copies would conflict with every new release tag.
src/drevalis/_version.py
