# ──────────────────────────────────────────────────────────────────────────────
# Drevalis Creator Studio — Environment Configuration
# Copy this file to .env and fill in the required values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# APP_NAME=Drevalis Creator Studio
# DEBUG=false

# ── Database (PostgreSQL + asyncpg) ──────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://drevalis:drevalis@localhost:5432/drevalis
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Storage ───────────────────────────────────────────────────────────────────
# Root directory for all generated media (episodes, audiobooks, models, music).
# Point to an external drive or NAS mount for more space.
# STORAGE_BASE_PATH=./storage

# ── Encryption (REQUIRED) ────────────────────────────────────────────────────
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used to encrypt API keys, YouTube OAuth tokens, and other secrets at rest.
ENCRYPTION_KEY=CHANGE_ME_generate_a_real_fernet_key

# ── LM Studio (local LLM endpoint) ──────────────────────────────────────────
# Any OpenAI-compatible server works (LM Studio, Ollama, vLLM, etc.)
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_DEFAULT_MODEL=local-model

# ── Anthropic (Claude — optional fallback) ───────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── ComfyUI (local image/video generation) ───────────────────────────────────
# Additional servers can be registered in the UI under Settings > ComfyUI.
# COMFYUI_DEFAULT_URL=http://localhost:8188

# ── Piper TTS ────────────────────────────────────────────────────────────────
# Download .onnx voice models from https://github.com/rhasspy/piper/blob/master/VOICES.md
# PIPER_MODELS_PATH=./storage/models/piper

# ── Kokoro TTS (optional) ────────────────────────────────────────────────────
# High-quality local TTS. Install with: pip install .[kokoro]
# KOKORO_MODELS_PATH=./storage/models/kokoro

# ── FFmpeg ────────────────────────────────────────────────────────────────────
# FFMPEG_PATH=ffmpeg

# ── Video Defaults ───────────────────────────────────────────────────────────
# VIDEO_WIDTH=1080
# VIDEO_HEIGHT=1920
# VIDEO_FPS=30
# VIDEO_MAX_DURATION=60

# ── YouTube Integration ──────────────────────────────────────────────────────
# Get credentials from Google Cloud Console > APIs & Services > Credentials.
# Enable YouTube Data API v3 at https://console.developers.google.com/apis/api/youtube.googleapis.com
# Create an OAuth 2.0 Client ID (Web Application) and add the redirect URI below.
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/youtube/callback

# ── Authentication (optional) ────────────────────────────────────────────────
# If set, all /api/ and /ws/ requests require Authorization: Bearer <token>.
# Leave empty for local development (no auth required).
# API_AUTH_TOKEN=

# ── Session cookies ──────────────────────────────────────────────────────────
# Dedicated HMAC secret for the team-mode session cookie. When unset, the app
# falls back to ENCRYPTION_KEY for backward-compat — but production should set
# this independently so a Fernet-key leak doesn't also yield session forgery.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SESSION_SECRET=

# Set the Secure flag on the session cookie (set True behind HTTPS).
# Default False so local-HTTP dev still works.
# COOKIE_SECURE=false

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum number of episodes generating simultaneously.
# MAX_CONCURRENT_GENERATIONS=4

# ── Container resource caps ──────────────────────────────────────────────────
# docker-compose.yml hard-limits each service via ``deploy.resources.limits``.
# Defaults fit an 8-CPU / 16 GB minimum host (typical small VPS). Raise these
# on a beefier workstation — Docker enforces these at the container level, so
# higher values let the app/worker eat more of the host when busy.
#
# Constraint: Docker REJECTS the stack if any single service's ``cpus`` value
# exceeds the host's total CPU count. Add up your real CPU count first.
#
# POSTGRES_CPUS=2
# POSTGRES_MEMORY=2G
# REDIS_CPUS=1
# REDIS_MEMORY=1G
# APP_CPUS=4
# APP_MEMORY=4G
# WORKER_CPUS=6
# WORKER_MEMORY=8G

# ── License Server / Stripe Price IDs (license-server service only) ─────────
# These belong in the license-server's .env file (not the app's). Documented
# here for discoverability. Each value is a Stripe Price ID (price_xxx) —
# never hardcode. Update the annual prices to reflect the 20%-off math
# (monthly × 10) when rolling out the pricing refresh.
# STRIPE_PRICE_CREATOR_MONTHLY=price_xxx
# STRIPE_PRICE_CREATOR_YEARLY=price_xxx    # monthly × 10 — 20% off
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_YEARLY=price_xxx        # monthly × 10 — 20% off
# STRIPE_PRICE_STUDIO_MONTHLY=price_xxx
# STRIPE_PRICE_STUDIO_YEARLY=price_xxx     # monthly × 10 — 20% off
# STRIPE_PRICE_LIFETIME_PRO=price_xxx      # one-time CHF 599, Lifetime (Pro)
# LIFETIME_UPDATE_WINDOW_DAYS=1095         # 3 years of free updates
