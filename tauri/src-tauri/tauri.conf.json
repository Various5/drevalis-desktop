{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drevalis Creator Studio",
  "version": "0.1.0-alpha.12",
  "identifier": "com.drevalis.studio",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Drevalis Creator Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "dmg"],
    "icon": [
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "AI-powered YouTube Shorts and audiobook studio",
    "longDescription": "Local-first AI video and audiobook creation studio. LLM-driven scripts, multi-provider TTS, ComfyUI scene generation, and one-click YouTube upload.",
    "publisher": "Drevalis",
    "copyright": "Copyright (c) 2026 Drevalis",
    "resources": {
      "../../dist/drevalis/drevalis.exe": "backend/drevalis.exe",
      "../../dist/drevalis/_internal/": "backend/_internal/"
    },
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "currentUser",
        "compression": "lzma"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Various5/drevalis-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwQjQ2QzExNUZFNTM2ClJXUTI1VjhSYkxUUUFFcnBUY3htN0hCVzZPb2pIRUFRekhMRUY0dGtBWHRPWHAvTGJ4cks1alpOCg=="
    }
  }
}
