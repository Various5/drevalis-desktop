# Copy to .env for production (or local dev).
#
# Self-hosted (Hetzner/any VPS): this .env file is read by docker-compose.yml
#   — keep it at /srv/drevalis-license/.env on the server, chmod 600.
# Fly.io alternate: these values are set via `fly secrets set` (see fly.toml).
#
# Never commit .env to git — the .gitignore excludes it.

# Required: Ed25519 private key that signs issued JWTs. The matching public
# key is embedded in the client app at
# src/drevalis/core/license/keys.py. Rotate by adding a second public
# key to the client, then swapping this value.
LICENSE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
...paste full PEM content...
-----END PRIVATE KEY-----"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs (create in Stripe Dashboard → Products, one price per tier+interval).
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_YEARLY=price_...

# Admin access
ADMIN_TOKEN=

# Email delivery (leave blank for log-only in dev)
RESEND_API_KEY=
RESEND_FROM="Drevalis <no-reply@drevalis.com>"

# URLs used in Stripe Checkout
APP_BASE_URL=https://drevalis.com
CHECKOUT_SUCCESS_URL=https://drevalis.com/thank-you
CHECKOUT_CANCEL_URL=https://drevalis.com/pricing

# SQLite path. Inside the container this must be /data/licenses.db
# (the Dockerfile sets it, and the docker-compose bind-mounts ./data here).
# Only override for LOCAL bare-metal development:
# DATABASE_PATH=./licenses.db
